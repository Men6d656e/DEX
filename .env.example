# DEX Dashboard Environment Variables
# ===================================
# Copy this file to frontend/.env.local and fill in your values.

# CoinGecko API Key (Optional but recommended)
# Get a free API key: https://www.coingecko.com/en/api
# Without this key, the chart will fall back to simulated data.
# NEXT_PUBLIC_COINGECKO_API_KEY=your_api_key_here
